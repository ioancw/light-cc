# Light CC environment variables
# Copy to .env and fill in values. .env is gitignored.
#
# For a production deploy, the REQUIRED values are marked [REQUIRED PROD]; the
# rest have safe defaults or are optional.

# ── Core secrets ──────────────────────────────────────────────────────
# [REQUIRED] Anthropic API key for Claude model access.
ANTHROPIC_API_KEY=sk-ant-...

# [REQUIRED PROD] JWT signing secret. Must be a long random string. The app
# refuses to start in production if this is unset or left at the default.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Runtime environment: "development" (default), "staging", or "production".
# In production the app enforces a non-default JWT_SECRET and tightens logging.
ENV=production

# ── Bootstrap admin user ──────────────────────────────────────────────
# Created by scripts/entrypoint.sh on first run if both are set. Re-runs are
# no-ops (the entrypoint skips creation if the email already exists).
# [REQUIRED PROD] — also used as the Let's Encrypt account email.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-a-strong-password
ADMIN_NAME=Admin

# ── Database ──────────────────────────────────────────────────────────
# Prod: set to Postgres. Dev: unset falls back to SQLite at data/lightcc.db.
# This env var ALWAYS wins over any value in config.yaml.
DATABASE_URL=postgresql+asyncpg://lightcc:CHANGE_ME@postgres:5432/lightcc

# Password used by the postgres container + the DATABASE_URL above. Keep them
# in sync. Dev default "lightcc" is fine locally, MUST be changed in prod.
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis (optional but recommended) ──────────────────────────────────
# Enables cross-replica rate limiting + pub/sub fanout. If unset, the app
# uses in-memory fallbacks (fine for single-replica deploys).
REDIS_URL=redis://redis:6379/0

# ── TLS / reverse proxy ───────────────────────────────────────────────
# [REQUIRED PROD] Your public hostname. Caddy will obtain a Let's Encrypt cert
# for this name. DNS must resolve to the VPS before first boot.
DOMAIN=lightcc.example.com

# ── Optional model providers ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Web search backend ────────────────────────────────────────────────
# Tavily is the preferred WebSearch backend (optimized for LLM consumption).
# Get a key at https://app.tavily.com. If unset, WebSearch falls back to DuckDuckGo.
# TAVILY_API_KEY=tvly-...

# ── Object storage (optional) ─────────────────────────────────────────
# If set, uploads and generated artifacts go to S3 instead of local disk.
# S3_BUCKET=
# S3_REGION=us-east-1

# ── Backups ───────────────────────────────────────────────────────────
# How many days of pg_dump snapshots to retain. Used by the postgres-backup
# service in docker-compose.prod.yml. Default 14.
# BACKUP_RETENTION_DAYS=14

# ── Observability (optional) ──────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# GRAFANA_PASSWORD=change-me   # only if using docker-compose.observability.yml

# ── Misc ──────────────────────────────────────────────────────────────
# Host port the app binds. Only effective without the prod Caddy overlay
# (Caddy terminates on 80/443 and proxies to the internal app:8000).
# PORT=8000
