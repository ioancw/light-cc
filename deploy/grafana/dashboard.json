{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(lcc_requests_total[5m])",
          "legendFormat": "{{user_id}} / {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "lcc_active_sessions" }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(lcc_errors_total[5m])",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "errors/s", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    },
    {
      "title": "Agent Loop Duration (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(lcc_agent_loop_duration_seconds_bucket[5m]))",
          "legendFormat": "P50 {{model}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lcc_agent_loop_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Tool Call Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(lcc_tool_calls_total[1h])",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "title": "Tool Execution Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(lcc_tool_call_duration_seconds_bucket[5m]))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Token Usage Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(lcc_token_usage_total[5m])",
          "legendFormat": "{{model}} {{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "tokens/s" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["light-cc"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Light CC Overview",
  "uid": "light-cc-overview",
  "version": 1
}
