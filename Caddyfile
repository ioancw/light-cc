# Caddy config for Light CC production deployment.
#
# Caddy terminates TLS and proxies all traffic to the app container.
# Auto-obtains and renews Let's Encrypt certificates based on DOMAIN + ADMIN_EMAIL.

{$DOMAIN}, www.{$DOMAIN} {
    # Email for Let's Encrypt account + renewal reminders
    tls {$ADMIN_EMAIL}

    # gzip + zstd where supported
    encode zstd gzip

    # Hardening headers. The Svelte build inlines all JS/CSS locally, so
    # default-src 'self' + connect-src 'self' wss: is enough for the app.
    # 'unsafe-inline' on style-src is required for Svelte's scoped styles
    # (these are injected as <style> blocks, no user-controlled input).
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), accelerometer=(), gyroscope=()"
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' wss: https:; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        # Remove the Caddy server banner
        -Server
    }

    # WebSocket endpoint -- needs Connection: Upgrade
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket app:8000

    # Everything else
    reverse_proxy app:8000 {
        # Preserve client IP for the app's logs / rate limits
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Access logs to stdout (docker logs caddy); tune as needed
    log {
        output stdout
        format json
    }
}
